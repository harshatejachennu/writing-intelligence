# ─── Supabase (required to boot) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ─── Model API keys (ALL OPTIONAL) ───────────────────────────────────────────
# Absent key => that route automatically falls back to Manual Mode.
# The app runs fully in Manual Mode with none of these set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
