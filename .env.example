# ─── Supabase (required to boot) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ─── Model API keys (ALL OPTIONAL) ───────────────────────────────────────────
# Absent key => that route automatically falls back to Manual Mode.
# The app runs fully in Manual Mode with none of these set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=

# ─── Execution control (OPTIONAL) ────────────────────────────────────────────
# Global execution preference; per-page and per-step overrides exist in the UI.
#   manual_only | api_only | smart | api_first_manual_fallback | manual_first_api_optional
# smart (default): quality steps (analyzer/planner/generator/critic/reviser/
# inspiration) -> Manual; structured steps -> API when a key exists.
# api_only: failures ERROR instead of falling back to Manual.
EXECUTION_PREFERENCE=smart

# Model served when a route falls through to OpenRouter without an explicit id.
# Any OpenRouter id works: openrouter/auto, openrouter/free, vendor/model:free, ...
OPENROUTER_DEFAULT_MODEL=openrouter/auto

# API-mode per-call timeout in milliseconds (default 90000).
API_TIMEOUT_MS=90000

# ─── Optional ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
